<aside class="sidebar" data-sidebar>
  <div class="sidebar-top">
    <a href="/dashboard" class="sidebar-brand">
      <span class="brand-mark">K</span>
      <div class="brand-copy">
        <strong>Kuizzosh</strong>
        <span>Host Console</span>
      </div>
    </a>
    <button class="sidebar-toggle" type="button" data-sidebar-toggle aria-label="Toggle sidebar">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4 7h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 17h10"></path>
      </svg>
    </button>
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 11 12 4l8 7"></path>
          <path d="M6 10.5V20h12v-9.5"></path>
        </svg>
      </span>
      <span class="nav-text">Kuizzosh</span>
    </a>
    <a href="/quizzes" class="nav-link <%= currentPath === '/quizzes' || currentPath.startsWith('/quizzes/') ? 'active' : '' %>">
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 8.5 12 4l6 4.5v7L12 20l-6-4.5Z"></path>
          <path d="M9 11.5h6"></path>
          <path d="M9 14.5h4"></path>
        </svg>
      </span>
      <span class="nav-text">Quizzes</span>
    </a>
    <a href="/polls" class="nav-link <%= currentPath === '/polls' || currentPath.startsWith('/polls/') ? 'active' : '' %>">
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 4v16"></path>
          <path d="M5 9h14"></path>
          <path d="M5 15h9"></path>
        </svg>
      </span>
      <span class="nav-text">Polls</span>
    </a>
    <a href="/rankings" class="nav-link <%= currentPath === '/rankings' || currentPath.startsWith('/rankings/') ? 'active' : '' %>">
      <span class="nav-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 19h14"></path>
          <path d="M7 15 10 9l3 4 4-7"></path>
        </svg>
      </span>
      <span class="nav-text">Rankings</span>
    </a>
  </nav>

  <div class="sidebar-bottom">
    <div class="account-chip">
      <div class="account-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
      <div class="account-copy">
        <strong><%= user.name %></strong>
        <span><%= user.email %></span>
      </div>
    </div>

    <form action="/logout" method="post">
      <button class="secondary-button sidebar-logout" type="submit">Logout</button>
    </form>
  </div>
</aside>
