<%- include("partials/head", { title, pageStyles: ["/css/pages/fast-click-join.css"] }) %>

<main class="quiz-player-page quiz-player-page-join<%= participant ? ' quiz-player-page-live' : '' %>">
  <% if (!participant) { %>
    <section class="quiz-player-shell quiz-player-shell-compact quiz-player-entry-shell">
      <header class="quiz-player-entry-top">
        <div class="quiz-player-entry-brand">
          <span class="quiz-player-entry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M8 5h8"></path>
              <path d="M12 5v6"></path>
              <path d="m9 11 3 8 3-8"></path>
            </svg>
          </span>
          <div class="quiz-player-entry-brand-copy">
            <span class="section-pill">Fast Click</span>
            <span class="quiz-player-entry-brand-hint">Join from your device</span>
          </div>
        </div>

        <div class="quiz-player-entry-chip-row">
          <div class="quiz-player-entry-chip quiz-player-entry-chip-joined">
            <span class="quiz-player-entry-chip-copy">
              <span>Joined</span>
              <strong data-fast-click-join-count><%= participantCount || 0 %></strong>
            </span>
          </div>
          <div class="quiz-player-entry-chip quiz-player-entry-chip-status <%= joinState === 'lobby' ? 'is-live' : joinState === 'finished' ? 'is-late' : 'is-waiting' %>" data-fast-click-join-state-chip>
            <span class="quiz-player-entry-chip-copy">
              <span>Status</span>
              <strong data-fast-click-join-state-label><%= joinState === 'lobby' ? 'Lobby Open' : joinState === 'finished' ? 'Finished' : 'Started' %></strong>
            </span>
          </div>
        </div>
      </header>

      <div class="quiz-player-entry-main">
        <div class="quiz-player-entry-overview">
          <section class="quiz-player-entry-hero">
            <h1><%= room.title %></h1>
            <p>Join with your nickname, wait for the signal, then tap the button as fast as you can when it turns green.</p>
          </section>

          <section class="quiz-player-entry-joined">
            <span class="section-pill">Players Joined</span>
            <strong data-fast-click-join-count-hero><%= participantCount || 0 %></strong>
            <p data-fast-click-join-count-label>
              <%= Number(participantCount || 0) === 1
                ? '1 player is already in the room.'
                : `${Number(participantCount || 0)} players are already in the room.` %>
            </p>
          </section>
        </div>

        <section class="quiz-player-join-card quiz-player-entry-join" data-fast-click-join-gate data-join-state="<%= joinState %>">
          <script type="application/json" data-quiz-live-realtime-config><%- serializedRealtimeConfig %></script>

          <% if (joinError) { %>
            <div class="dashboard-inline-flash dashboard-inline-flash-error"><%= joinError %></div>
          <% } %>

          <div class="quiz-player-entry-join-head">
            <div class="quiz-player-join-copy quiz-player-entry-join-copy">
              <h2 data-fast-click-join-heading><%= joinState === 'lobby' ? 'You can join now' : joinState === 'finished' ? 'Session ended' : "Opss, you're late." %></h2>
              <p data-fast-click-join-status-text>
                <%= joinState === 'lobby'
                  ? 'The room is open. Enter your nickname and get ready.'
                  : joinState === 'finished'
                    ? 'This fast click room is already finished.'
                    : 'The round has already started, so new players cannot join now.' %>
              </p>
            </div>
          </div>

          <form action="/fast-click/join/<%= room.room_code %>/join" method="post" class="quiz-player-join-form quiz-player-entry-form" data-fast-click-join-form <%= joinState === 'lobby' ? '' : 'hidden' %>>
            <label class="field quiz-player-entry-field">
              <span>Nickname</span>
              <input type="text" name="displayName" maxlength="32" placeholder="Enter your nickname" />
            </label>
            <button type="submit" class="primary-button quiz-player-entry-submit" data-fast-click-join-submit>
              Join Fast Click
            </button>
          </form>

          <p class="quiz-player-entry-note" data-fast-click-join-note <%= joinState === 'lobby' ? '' : 'hidden' %>>Use the same nickname you want shown in the live ranking list.</p>
          <p class="quiz-player-entry-late-note" data-fast-click-join-late-note <%= joinState === 'lobby' ? 'hidden' : '' %>>This room is no longer accepting new players.</p>
        </section>
      </div>
    </section>
  <% } else { %>
    <section
      class="quiz-player-shell quiz-player-shell-live"
      data-fast-click-player
      data-state-url="/api/fast-click/join/<%= room.room_code %>/state"
      data-click-url="/api/fast-click/join/<%= room.room_code %>/click"
    >
      <script type="application/json" data-fast-click-player-data><%- serializedLiveSnapshot %></script>
      <script type="application/json" data-quiz-live-realtime-config><%- serializedRealtimeConfig %></script>
      <div class="quiz-player-identity">
        <span>Playing as</span>
        <strong><%= participant.display_name %></strong>
      </div>
    </section>
  <% } %>
</main>

<script src="/vendor/supabase/supabase.js"></script>
<script src="/js/quiz-live-realtime.js"></script>
<script src="/js/fast-click-player.js"></script>
<%- include("partials/foot") %>
