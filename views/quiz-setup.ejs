<%- include("partials/head", { title, pageStyles: ["/css/pages/quiz-setup.css"] }) %>

<main class="dashboard-page">
  <%- include("partials/sidebar", { user, currentPath }) %>

  <section class="dashboard-main dashboard-main-clean quiz-setup-page">
    <div class="setup-backbar">
      <a href="/quizzes" class="setup-backlink">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 6 9 12l6 6"></path>
        </svg>
        <span>Back to Quizzes</span>
      </a>
    </div>

    <% if (flashSuccess) { %>
      <div class="dashboard-inline-flash dashboard-inline-flash-success"><%= flashSuccess %></div>
    <% } %>
    <% if (flashError) { %>
      <div class="dashboard-inline-flash dashboard-inline-flash-error"><%= flashError %></div>
    <% } %>

    <form
      action="/quizzes/<%= item.id %>/setup"
      method="post"
      class="quiz-builder-form"
      data-quiz-builder
      data-quiz-id="<%= item.id %>"
      data-quiz-start-url="/quizzes/<%= item.id %>/start"
      data-initial-section-index="<%= initialActiveSectionIndex %>"
      data-initial-question-index="<%= initialActiveQuestionIndex %>"
    >
      <input type="hidden" name="builderState" data-builder-state-input />
      <input type="hidden" name="activeSectionIndex" data-active-section-input />
      <input type="hidden" name="activeQuestionIndex" data-active-question-input />

      <section class="setup-hero setup-hero-compact">
        <div class="setup-hero-copy">
          <span class="section-pill">Quiz Setup</span>
          <h1><%= item.title %></h1>
          <div class="setup-chip-row">
            <div class="setup-chip-list">
              <span class="visibility-badge visibility-badge-<%= item.visibility %>">
                <%= item.visibility.charAt(0).toUpperCase() + item.visibility.slice(1) %>
              </span>
              <span class="status-badge status-badge-<%= item.status %>">
                <%= item.status.charAt(0).toUpperCase() + item.status.slice(1) %>
              </span>
              <span class="setup-meta-pill">
                <span>Quiz Code</span>
                <strong><%= item.quiz_code %></strong>
              </span>
              <span class="setup-meta-pill">
                <span>Duration</span>
                <strong><%= item.duration_label %></strong>
              </span>
            </div>
            <button
              type="button"
              class="setup-settings-trigger"
              data-open-quiz-settings
              aria-haspopup="dialog"
              aria-controls="quiz-settings-modal"
              aria-label="Open quiz settings"
              title="Quiz settings"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 6h-6"></path>
                <path d="M9 6H3"></path>
                <path d="M21 12h-10"></path>
                <path d="M5 12H3"></path>
                <path d="M21 18h-4"></path>
                <path d="M11 18H3"></path>
                <circle cx="12" cy="6" r="3"></circle>
                <circle cx="8" cy="12" r="3"></circle>
                <circle cx="14" cy="18" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>

        <div class="quiz-builder-top-actions">
          <a href="/quizzes" class="secondary-button">Back</a>
          <button type="submit" class="primary-button">Save Quiz</button>
        </div>
      </section>

      <section class="quiz-builder-layout">
        <aside class="quiz-builder-outline">
          <div class="quiz-builder-outline-header">
            <div>
              <h2>Sections</h2>
              <p>Organize the quiz flow.</p>
            </div>
            <button
              type="button"
              class="quiz-outline-add-button"
              data-add-section
              aria-label="Add section"
              title="Add section"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5v14"></path>
                <path d="M5 12h14"></path>
              </svg>
            </button>
          </div>
          <div class="quiz-section-nav" data-section-nav></div>
        </aside>

        <div class="quiz-builder-canvas">
          <div class="quiz-section-panels" data-section-panels></div>
        </div>
      </section>

      <div class="quiz-builder-footer">
        <div class="quiz-builder-footer-copy">
          <strong>Leaderboard quiz prototype</strong>
          <span>Sections, questions, correct choices, timers, and live quiz settings are all saved into SQL.</span>
        </div>
        <div class="quiz-builder-footer-actions">
          <a href="/quizzes/<%= item.id %>/start" class="secondary-button quiz-builder-footer-play">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m10 8 6 4-6 4Z"></path>
            </svg>
            <span>Play</span>
          </a>
          <button type="submit" class="primary-button">Save Quiz</button>
        </div>
      </div>

      <div
        id="quiz-settings-modal"
        class="modal-overlay"
        data-quiz-settings-modal
        aria-hidden="true"
      >
        <button type="button" class="modal-backdrop" data-close-quiz-settings aria-label="Close settings"></button>

        <section class="modal-panel quiz-settings-panel" role="dialog" aria-modal="true" aria-labelledby="quiz-settings-title">
          <div class="modal-header">
            <div>
              <h2 id="quiz-settings-title">Leaderboard Settings</h2>
              <p>Control how the live quiz reveals rankings, answers, and randomization.</p>
            </div>
            <button type="button" class="modal-close" data-close-quiz-settings aria-label="Close settings">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 6 18 18"></path>
                <path d="M18 6 6 18"></path>
              </svg>
            </button>
          </div>

          <div class="quiz-settings-list">
            <label class="quiz-setting-item">
              <span class="quiz-setting-copy">
                <strong>Leaderboard</strong>
                <span>Rank participants by correct answers first, then fastest correct answer time.</span>
              </span>
              <span class="quiz-setting-switch">
                <input type="checkbox" name="leaderboardEnabled" <%= quizSettings.leaderboardEnabled ? 'checked' : '' %> />
                <span class="quiz-setting-slider" aria-hidden="true"></span>
              </span>
            </label>

            <label class="quiz-setting-item">
              <span class="quiz-setting-copy">
                <strong>Reveal Correct Answer</strong>
                <span>Show the correct answer immediately after each question.</span>
              </span>
              <span class="quiz-setting-switch">
                <input type="checkbox" name="showCorrectAnswer" <%= quizSettings.showCorrectAnswer ? 'checked' : '' %> />
                <span class="quiz-setting-slider" aria-hidden="true"></span>
              </span>
            </label>

            <label class="quiz-setting-item">
              <span class="quiz-setting-copy">
                <strong>Shuffle Questions</strong>
                <span>Randomize the order of quiz questions for participants.</span>
              </span>
              <span class="quiz-setting-switch">
                <input type="checkbox" name="randomizeQuestions" <%= quizSettings.randomizeQuestions ? 'checked' : '' %> />
                <span class="quiz-setting-slider" aria-hidden="true"></span>
              </span>
            </label>

            <label class="quiz-setting-item">
              <span class="quiz-setting-copy">
                <strong>Shuffle Choices</strong>
                <span>Randomize the answer choices shown on each question.</span>
              </span>
              <span class="quiz-setting-switch">
                <input type="checkbox" name="randomizeChoices" <%= quizSettings.randomizeChoices ? 'checked' : '' %> />
                <span class="quiz-setting-slider" aria-hidden="true"></span>
              </span>
            </label>
          </div>

          <div class="modal-actions">
            <button type="button" class="secondary-button" data-close-quiz-settings>Done</button>
          </div>
        </section>
      </div>
    </form>

    <form id="quiz-live-reset-form" action="/quizzes/<%= item.id %>/live/reset" method="post"></form>
  </section>
</main>

<script type="application/json" data-quiz-builder-data><%- serializedBuilderState %></script>
<script src="/js/quiz-builder.js"></script>
<%- include("partials/foot") %>
